# ============================================================
# Traveler - 企业级旅游规划智能体
# ============================================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# ---------- LLM Provider API Keys ----------
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
# DEEPSEEK_API_KEY=sk-xxx

# ---------- Default Model ----------
# 可选: gpt-4o / claude-sonnet-4-20250514 / deepseek-chat
DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL_ID=gpt-4o

# ---------- Database ----------
# 开发环境使用 SQLite，生产环境建议 PostgreSQL
DATABASE_URL=sqlite:///data/traveler.db
# DATABASE_URL=postgresql://user:password@localhost:5432/traveler

# ---------- Vector DB ----------
# 可选: chroma / lancedb / pgvector
VECTOR_DB_PROVIDER=chroma
VECTOR_DB_PATH=data/chromadb

# ---------- MCP Servers ----------
# MCP 服务器参数在 src/traveler/config/mcp_servers.py 中配置
BRAVE_API_KEY=

# ---------- External APIs ----------
# 可选的旅游数据 API
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ---------- Application ----------
APP_NAME=Traveler
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=DEBUG
APP_HOST=0.0.0.0
APP_PORT=8000
